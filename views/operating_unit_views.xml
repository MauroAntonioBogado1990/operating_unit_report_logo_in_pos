<?xml version="1.0" encoding="utf-8"?>
<odoo>
  

    <!-- Unidad Operativa: agrega campo report_logo -->
    <record id="view_operating_unit_form_report_logo" model="ir.ui.view">
      <field name="name">operating.unit.form.report.logo</field>
      <field name="model">operating.unit</field>
      <field name="inherit_id" ref="operating_unit.view_operating_unit_form"/>
      <field name="arch" type="xml">
        <xpath expr="//field[@name='name']" position="after">
          <field name="report_logo" widget="image" class="oe_avatar"/>
        </xpath>
      </field>
    </record>

    <!-- account.move: campo OU readonly, se asigna automáticamente desde el diario -->
    <record id="view_move_form_inherit_operating_unit" model="ir.ui.view">
      <field name="name">account.move.form.inherit.operating.unit</field>
      <field name="model">account.move</field>
      <field name="inherit_id" ref="account.view_move_form"/>
      <field name="arch" type="xml">
        <xpath expr="//field[@name='company_id']" position="after">
          <field name="operating_unit_id"
                 readonly="1"
                 options="{'no_create': True}"
                 attrs="{'invisible': [('operating_unit_id', '=', False)]}"
                 help="Se asigna automáticamente desde el Diario de Venta."/>
        </xpath>
      </field>
    </record>

    <!-- account.journal: configuración principal de la OU -->
    <record id="view_journal_form_inherit_operating_unit" model="ir.ui.view">
      <field name="name">account.journal.form.inherit.operating.unit</field>
      <field name="model">account.journal</field>
      <field name="inherit_id" ref="account.view_account_journal_form"/>
      <field name="arch" type="xml">
        <xpath expr="//field[@name='name']" position="after">
        <br/>
        Unidad Operativa
          <field name="operating_unit_id"
                 options="{'no_create': True}"
                 help="Todas las facturas y recibos del POS asociados a este diario usarán el logo de esta Unidad Operativa."/>
        </xpath>
      </field>
    </record>

    <!-- pos.config: muestra el diario de ventas (fuente principal del logo)
         y permite asignar una OU manual como fallback -->
    <record id="view_pos_config_form_inherit_operating_unit" model="ir.ui.view">
      <field name="name">pos.config.form.inherit.operating.unit</field>
      <field name="model">pos.config</field>
      <field name="inherit_id" ref="point_of_sale.pos_config_view_form"/>
      <field name="arch" type="xml">
        <xpath expr="//div[@id='title']" position="after">
        <br/>
        Unidad Operativa
          <field name="operating_unit_id"
                 options="{'no_create': True}"
                 help="El logo de esta Unidad Operativa se usará en todas las facturas emitidas con este diario."/>
        </xpath>
            <!--
              El logo del recibo se toma del Diario de Ventas (invoice_journal_id).
              Configurá la OU directamente en ese diario desde
              Contabilidad > Configuración > Diarios.
            -->
            <!-- <field name="invoice_journal_id" readonly="1"
                   string="Diario de Ventas (fuente del logo)"/> -->
            <!-- Solo completar si el diario de ventas no tiene OU asignada -->
            <!-- <field name="operating_unit_id"
                   options="{'no_create': True}"
                   help="Opcional. Solo aplica si el Diario de Ventas no tiene Unidad Operativa asignada."/>
           -->
        
      </field>
    </record>

  
</odoo>