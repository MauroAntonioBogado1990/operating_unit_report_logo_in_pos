<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>

    <!-- Unidad Operativa: agrega campo report_logo -->
    <record id="view_operating_unit_form_report_logo" model="ir.ui.view">
      <field name="name">operating.unit.form.report.logo</field>
      <field name="model">operating.unit</field>
      <field name="inherit_id" ref="operating_unit.view_operating_unit_form"/>
      <field name="arch" type="xml">
        <xpath expr="//field[@name='name']" position="after">
          <field name="report_logo" widget="image" class="oe_avatar"/>
        </xpath>
      </field>
    </record>

    <!-- account.move: muestra la OU como campo informativo (readonly).
         El usuario NO la elige: se asigna automáticamente desde el diario. -->
    <record id="view_move_form_inherit_operating_unit" model="ir.ui.view">
      <field name="name">account.move.form.inherit.operating.unit</field>
      <field name="model">account.move</field>
      <field name="inherit_id" ref="account.view_move_form"/>
      <field name="arch" type="xml">
        <xpath expr="//field[@name='company_id']" position="after">
          <field name="operating_unit_id"
                 readonly="1"
                 options="{'no_create': True}"
                 attrs="{'invisible': [('operating_unit_id', '=', False)]}"
                 help="Se asigna automáticamente según el Diario de Venta seleccionado."/>
        </xpath>
      </field>
    </record>

    <!-- account.journal: selector de Unidad Operativa.
         Esta es la configuración clave: al asignar la OU al diario,
         todas las facturas generadas con ese diario heredan su logo. -->
    <record id="view_journal_form_inherit_operating_unit" model="ir.ui.view">
      <field name="name">account.journal.form.inherit.operating.unit</field>
      <field name="model">account.journal</field>
      <field name="inherit_id" ref="account.view_account_journal_form"/>
      <field name="arch" type="xml">
        <xpath expr="//field[@name='name']" position="after">
          <field name="operating_unit_id"
                 options="{'no_create': True}"
                 help="El logo de esta Unidad Operativa se usará en todas las facturas emitidas con este diario."/>
        </xpath>
      </field>
    </record>

    <!-- pos.config: selector de Unidad Operativa para el POS.
         El logo se imprimirá en todos los recibos de este punto de venta. -->
    <record id="view_pos_config_form_inherit_operating_unit" model="ir.ui.view">
      <field name="name">pos.config.form.inherit.operating.unit</field>
      <field name="model">pos.config</field>
      <field name="inherit_id" ref="point_of_sale.pos_config_view_form"/>
      <field name="arch" type="xml">
        <xpath expr="//div[@id='title']" position="after">
          <group string="Unidad Operativa">
            <field name="operating_unit_id"
                   options="{'no_create': True}"
                   help="El logo de esta Unidad Operativa se imprimirá en los recibos del POS."/>
          </group>
        </xpath>
      </field>
    </record>

  </data>
</odoo>